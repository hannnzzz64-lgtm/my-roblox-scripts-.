local function GetClosestPlayerInFOV()
    local target = nil
    local shortestDist = FOVSizeValue
    local center = (FOVModeVal == "Mobile") and UserInputService:GetMouseLocation() or (Camera.ViewportSize / 2)

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local part = v.Character:FindFirstChild("Head") or v.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local magnitude = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if magnitude < shortestDist then
                        shortestDist = magnitude
                        target = part
                    end
                end
            end
        end
    end
    return target
end

-- Fungsi Safe Teleport (Aman, Lambat & Anti-Stuck)
local function SafeTeleportTo(targetPosition)
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local rootPart = char.HumanoidRootPart
        local distance = (rootPart.Position - targetPosition).Magnitude
        
        local speed = 45 
        local duration = math.clamp(distance / speed, 1.5, 6.0) 

        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
        local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(targetPosition + Vector3.new(0, 3, 0))})
        
        local oldState = {}
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                oldState[part] = part.CanCollide
                part.CanCollide = false
            end
        end
        
        tween:Play()
        tween.Completed:Wait()

        for part, canCollide in pairs(oldState) do
            if part and part.Parent then
                part.CanCollide = canCollide
            end
        end
    end
end

