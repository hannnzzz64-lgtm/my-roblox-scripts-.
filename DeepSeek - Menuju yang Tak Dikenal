            else
                AimLine.Visible = false
            end
        else
            AimLine.Visible = false
        end
    else
        AimLine.Visible = false
    end

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer then
            if not EspCache[v] then
                EspCache[v] = {
                    Box = Drawing.new("Square"),
                    NameTag = Drawing.new("Text"),
                    HealthBarBg = Drawing.new("Square"),
                    HealthBar = Drawing.new("Square"),
                    TracerLine = Drawing.new("Line")
                }
                
                EspCache[v].Box.Visible = false
                EspCache[v].Box.Thickness = 1.5
                EspCache[v].Box.Color = Color3.fromRGB(0, 255, 255)
                EspCache[v].Box.Filled = false

                EspCache[v].NameTag.Visible = false
                EspCache[v].NameTag.Size = 13
                EspCache[v].NameTag.Center = true
                EspCache[v].NameTag.Outline = true
                EspCache[v].NameTag.Color = Color3.fromRGB(255, 255, 255)

                EspCache[v].HealthBarBg.Visible = false
                EspCache[v].HealthBarBg.Thickness = 1
                EspCache[v].HealthBarBg.Color = Color3.fromRGB(0, 0, 0)
                EspCache[v].HealthBarBg.Filled = true

                EspCache[v].HealthBar.Visible = false
                EspCache[v].HealthBar.Thickness = 1
                EspCache[v].HealthBar.Color = Color3.fromRGB(0, 255, 0)
                EspCache[v].HealthBar.Filled = true

                EspCache[v].TracerLine.Visible = false
                EspCache[v].TracerLine.Thickness = 1.5
                EspCache[v].TracerLine.Color = Color3.fromRGB(255, 255, 255)
            end

            local cache = EspCache[v]
            local char = v.Character
            local rootPart = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")

            if char and rootPart and humanoid and humanoid.Health &gt; 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                if onScreen then
                    local sizeFactor = math.clamp(1000 / (Camera.CFrame.Position - rootPart.Position).Magnitude, 0.3, 5)
                    local width = math.floor(25 * sizeFactor)
                    local height = math.floor(35 * sizeFactor)
                    local topLeft = Vector2.new(pos.X - width / 2, pos.Y - height / 2)

                    if EnableESPBox then
                        cache.Box.Size = Vector2.new(width, height)
                        cache.Box.Position = topLeft
                        cache.Box.Visible = true
                    else
                        cache.Box.Visible = false
                    end

                    if EnableESPName or EnableESPDistance then
                        local textDisplay = v.Name
                        if EnableESPDistance then
                            local dist = math.floor((Camera.CFrame.Position - rootPart.Position).Magnitude)
                            textDisplay = textDisplay .. " [" .. dist .. "m]"
                        end
                        if not EnableESPName then
                            textDisplay = EnableESPDistance and "[" .. math.floor((Camera.CFrame.Position - rootPart.Position).Magnitude) .. "m]" or ""
                        end
                        cache.NameTag.Text = textDisplay
                        cache.NameTag.Position = Vector2.new(pos.X, topLeft.Y - 16)
                        cache.NameTag.Visible = true
                    else
                        cache.NameTag.Visible = false
                    end

                    if EnableESPHealth then
                        local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
