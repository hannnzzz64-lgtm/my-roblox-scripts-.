                        cache.HealthBarBg.Size = Vector2.new(3, height)
                        cache.HealthBarBg.Position = Vector2.new(topLeft.X - 6, topLeft.Y)
                        cache.HealthBarBg.Visible = true

                        cache.HealthBar.Size = Vector2.new(1, barHeight)
                        cache.HealthBar.Position = Vector2.new(topLeft.X - 5, topLeft.Y + (height - barHeight))
                        cache.HealthBar.Visible = true
                    else
                        cache.HealthBarBg.Visible = false
                        cache.HealthBar.Visible = false
                    end

                    if EnableESPLine then
                        cache.TracerLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
