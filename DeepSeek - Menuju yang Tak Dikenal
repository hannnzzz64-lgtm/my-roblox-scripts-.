                        cache.TracerLine.Visible = true
                    else
                        cache.TracerLine.Visible = false
                    end
                else
                    cache.Box.Visible = false
                    cache.NameTag.Visible = false
                    cache.HealthBarBg.Visible = false
                    cache.HealthBar.Visible = false
                    cache.TracerLine.Visible = false
                end
            else
