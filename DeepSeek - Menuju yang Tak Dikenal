    Label.BackgroundTransparency = 1 Label.TextColor3 = Color3.fromRGB(170, 170, 170)
    Label.TextSize = 11 Label.Font = Enum.Font.Gotham Label.TextXAlignment = Enum.TextXAlignment.Left
