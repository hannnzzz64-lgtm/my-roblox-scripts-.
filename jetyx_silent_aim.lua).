-- Loop Utama Render (Hitbox, FOV Circle, Aim Line, & Full ESP)
RunService.RenderStepped:Connect(function()
    -- Hitbox Expander Head Logic (Aman untuk damage, tidak membuat musuh kebal/diam)
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local head = v.Character:FindFirstChild("Head")
            local humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if head and humanoid and humanoid.Health > 0 then
                if MasterHitbox and EnableHitboxHead then
                    head.Size = Vector3.new(HitboxSizeValue, HitboxSizeValue, HitboxSizeValue)
                    head.Transparency = HitboxTransparency
                    head.CanCollide = false
                    head.Massless = true
                else
                    head.Size = Vector3.new(2, 1, 1)
                    head.Transparency = 0
                    head.CanCollide = true
                    head.Massless = false
                end
            end
        end
    end

    -- FOV Circle Logic
    if ShowFOVCircle then
        FOVFrame.Visible = true
        FOVFrame.Size = UDim2.new(0, FOVSizeValue * 2, 0, FOVSizeValue * 2)
        if FOVModeVal == "Mobile" then
            local mouseLoc = UserInputService:GetMouseLocation()
            FOVFrame.Position = UDim2.new(0, mouseLoc.X, 0, mouseLoc.Y)
        else
            local viewportCenter = Camera.ViewportSize / 2
            FOVFrame.Position = UDim2.new(0, viewportCenter.X, 0, viewportCenter.Y)
        end
    else
        FOVFrame.Visible = false
    end

    -- Aim Line Logic
    if ShowAimLine then
        local target = GetClosestPlayerInFOV()
        if target then
            local screenPos, onScreen = Camera:WorldToViewportPoint(target.Position)
            if onScreen then
                AimLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                AimLine.To = Vector2.new(screenPos.X, screenPos.Y)
                AimLine.Visible = true
            else
                AimLine.Visible = false
            end
        else
            AimLine.Visible = false
        end
    else
        AimLine.Visible = false
    end

    -- Full ESP Rendering Logic
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer then
            if not EspCache[v] then
                EspCache[v] = {
                    Box = Drawing.new("Square"),
                    NameTag = Drawing.new("Text"),
                    HealthBarBg = Drawing.new("Square"),
                    HealthBar = Drawing.new("Square"),
                    TracerLine = Drawing.new("Line")
                }
                
                -- Box Config
                EspCache[v].Box.Visible = false
                EspCache[v].Box.Thickness = 1.5
                EspCache[v].Box.Color = Color3.fromRGB(0, 255, 255)
                EspCache[v].Box.Filled = false

                -- Name / Info Config
                EspCache[v].NameTag.Visible = false
                EspCache[v].NameTag.Size = 13
                EspCache[v].NameTag.Center = true
                EspCache[v].NameTag.Outline = true
                EspCache[v].NameTag.Color = Color3.fromRGB(255, 255, 255)

                -- Health Bar Background Config
                EspCache[v].HealthBarBg.Visible = false
                EspCache[v].HealthBarBg.Thickness = 1
                EspCache[v].HealthBarBg.Color = Color3.fromRGB(0, 0, 0)
                EspCache[v].HealthBarBg.Filled = true

                -- Health Bar Config
                EspCache[v].HealthBar.Visible = false
                EspCache[v].HealthBar.Thickness = 1
                EspCache[v].HealthBar.Color = Color3.fromRGB(0, 255, 0)
                EspCache[v].HealthBar.Filled = true

                -- Tracer Line Config
                EspCache[v].TracerLine.Visible = false
                EspCache[v].TracerLine.Thickness = 1.5
                EspCache[v].TracerLine.Color = Color3.fromRGB(255, 255, 255)
            end

            local cache = EspCache[v]
            local char = v.Character
            local rootPart = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")

            if char and rootPart and humanoid and humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                if onScreen then
                    local sizeFactor = math.clamp(1000 / (Camera.CFrame.Position - rootPart.Position).Magnitude, 0.3, 5)
                    local width = math.floor(25 * sizeFactor)
                    local height = math.floor(35 * sizeFactor)
                    local topLeft = Vector2.new(pos.X - width / 2, pos.Y - height / 2)

                    -- ESP Box
                    if EnableESPBox then
                        cache.Box.Size = Vector2.new(width, height)
                        cache.Box.Position = topLeft
                        cache.Box.Visible = true
                    else
                        cache.Box.Visible = false
                    end

                    -- ESP Name & Distance
                    if EnableESPName or EnableESPDistance then
                        local textDisplay = v.Name
                        if EnableESPDistance then
                            local dist = math.floor((Camera.CFrame.Position - rootPart.Position).Magnitude)
        
